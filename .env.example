# =============================================================================
# NST Retailer Onboarding — Environment Variables
# =============================================================================
# Copy this file to .env.local for local dev, and set these in Vercel for prod.
# Do NOT commit .env.local. Only .env.example is committed.
#
# Naming convention:
#   VITE_*           — exposed to the browser (client-safe only)
#   (no prefix)      — server-only (used in scripts, Supabase Edge Functions, etc.)

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
VITE_APP_URL=https://onboard.nationalsecuretransport.com
VITE_SUPPORT_PHONE=+1-XXX-XXX-XXXX
VITE_SUPPORT_EMAIL=onboarding@nationalsecuretransport.com

# -----------------------------------------------------------------------------
# Supabase (DB + Auth + Storage)
# -----------------------------------------------------------------------------
# Project: nst-onboarding (us-east-1)
# Project ref: rqmtikbgkplxmmchyujo
# Dashboard: https://supabase.com/dashboard/project/rqmtikbgkplxmmchyujo
#
# URL + publishable key below are client-safe and can be committed as defaults.
# SERVICE_ROLE_KEY stays server-side only — never expose to the browser.
# Set to 'true' to bypass real Supabase Auth in dev.
# Any email on /login signs you in with a fake session; useful before
# Salesforce is wired up to seed real accounts.
VITE_MOCK_AUTH=true

VITE_SUPABASE_URL=https://rqmtikbgkplxmmchyujo.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_4LXRS1XNJBGyyiXzO_6_7w_plGUBOiM
SUPABASE_SERVICE_ROLE_KEY=                      # paste from dashboard → server-side only
SUPABASE_JWT_SECRET=                            # paste from dashboard

# -----------------------------------------------------------------------------
# Salesforce (server-side only — used by Edge Functions, not browser)
# -----------------------------------------------------------------------------
SALESFORCE_INSTANCE_URL=https://talariatransportation.my.salesforce.com
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
SALESFORCE_API_VERSION=v58.0
SALESFORCE_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# AWS Textract (server-side only)
# -----------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# -----------------------------------------------------------------------------
# Resend (server-side only — sample invoice emails)
# -----------------------------------------------------------------------------
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@nationalsecuretransport.com
RESEND_OPS_INBOX=operations@nationalsecuretransport.com

# -----------------------------------------------------------------------------
# PostHog (client-safe)
# -----------------------------------------------------------------------------
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com

# -----------------------------------------------------------------------------
# Sentry
# -----------------------------------------------------------------------------
VITE_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=nst
SENTRY_PROJECT=onboarding

# -----------------------------------------------------------------------------
# Feature flags (runtime, client-safe)
# -----------------------------------------------------------------------------
VITE_FEATURE_SPANISH_ENABLED=true
VITE_FEATURE_DEPOSIT_DRY_RUN_ENABLED=true
VITE_FEATURE_CHANGE_ORDER_DRY_RUN_ENABLED=true
